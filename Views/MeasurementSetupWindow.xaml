<Window x:Class="SurfaceTensionApp.Views.MeasurementSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Measurement Setup"
        Width="480" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        FontFamily="Inter">

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A55"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#808098"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="6,4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A3E"
                        BorderBrush="#3A3A52" BorderThickness="1" CornerRadius="4"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#808098"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#333350"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource DarkComboBoxToggle}"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="8,0,24,0" VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2A2A3E"
                                            BorderBrush="#3A3A52" BorderThickness="1" CornerRadius="4"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="20,16,20,8">
            <StackPanel>
                <!-- Section: Method & Load Cell -->
                <TextBlock Text="METHOD" FontSize="10" FontWeight="Bold" Foreground="#4A9EFF" Margin="0,0,0,8"/>

                <TextBlock Text="Measurement Method" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="MethodCombo" ItemsSource="{Binding MethodOptions}"
                          SelectedItem="{Binding Config.Method}" Height="28"/>

                <TextBlock Text="Load Cell" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding LoadCellOptions}"
                          SelectedItem="{Binding Config.LoadCellType}" Height="28"/>

                <!-- Section: Du Noüy Ring Parameters -->
                <StackPanel x:Name="RingPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Config.Method}" Value="Wilhelmy Plate">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="DU NOÜY RING" FontSize="10" FontWeight="Bold"
                               Foreground="#4A9EFF" Margin="0,8,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Ring Radius (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Config.RingRadius, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Wire Radius (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Config.WireRadius, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Ring Material" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Config.RingMaterial, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Section: Wilhelmy Plate Parameters -->
                <StackPanel x:Name="PlatePanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Config.Method}" Value="Wilhelmy Plate">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <TextBlock Text="WILHELMY PLATE" FontSize="10" FontWeight="Bold"
                               Foreground="#4A9EFF" Margin="0,8,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Plate Width (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Config.PlateWidth, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Plate Thickness (mm)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Config.PlateThickness, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Plate Material" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Config.PlateMaterial, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- Section: Calculation -->
                <TextBlock Text="CALCULATION" FontSize="10" FontWeight="Bold"
                           Foreground="#4A9EFF" Margin="0,8,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Correction Factor" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Config.CorrectionFactor, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Display Unit" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding UnitOptions}"
                                  SelectedItem="{Binding Config.Unit}" Height="28"/>
                    </StackPanel>
                </Grid>

                <!-- Section: Sample Information -->
                <TextBlock Text="SAMPLE INFORMATION" FontSize="10" FontWeight="Bold"
                           Foreground="#4A9EFF" Margin="0,8,0,8"/>

                <TextBlock Text="Liquid / Sample Name" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Config.LiquidName, UpdateSourceTrigger=PropertyChanged}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Temperature (°C)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Config.Temperature, TargetNullValue='', UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Sample ID" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Config.SampleId, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Operator" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Config.OperatorName, UpdateSourceTrigger=LostFocus}"/>

                <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Config.Notes, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap" MinHeight="50" AcceptsReturn="True"/>

                <TextBlock Text="All fields are optional. Only filled fields will appear in the PDF report."
                           FontSize="9" Foreground="#666680" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom button bar -->
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#3A3A52"
                Background="#252538" Padding="20,12">
            <Button Content="Close" Width="100" Height="32" HorizontalAlignment="Right"
                    Click="OnCloseClick">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4A9EFF"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="12,6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3A7EDC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>