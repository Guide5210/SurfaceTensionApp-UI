<Window x:Class="SurfaceTensionApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SurfaceTensionApp.Converters"
        xmlns:scott="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Surface Tension Tester v7.3 — Du Noüy Ring"
        Width="1400" Height="900" MinWidth="1100" MinHeight="700"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Grayscale"
        FontFamily="Inter">

    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#2A2A3E"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A55"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3A3A55"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8F0"/>
        </Style>
        <conv:BoolToConnectionBrush x:Key="ConnBrush"/>
        <conv:BoolToVisibility x:Key="BoolVis"/>
        <conv:InverseBoolToVisibility x:Key="InvBoolVis"/>
        <conv:HexToBrush x:Key="HexBrush"/>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A3A55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Full dark ComboBox template -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" Background="#2A2A3E"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="3"/>
                <Border Grid.Column="0" Background="#2A2A3E" BorderThickness="0" CornerRadius="3,0,0,3" Margin="1"/>
                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="#808098"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#333350"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource DarkComboBoxToggle}"
                                          Focusable="False" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, 
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              Margin="6,3,23,3" VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden" IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Background="Transparent" Foreground="White" CaretBrush="White"
                                     HorizontalAlignment="Left" VerticalAlignment="Center"
                                     Margin="3,3,23,3" Focusable="True"/>
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#2A2A3E"
                                            BorderBrush="#555577" BorderThickness="1" CornerRadius="3"/>
                                    <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="BorderBrush" Value="#555577"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#2A2A3E" BorderBrush="#555577" BorderThickness="1" 
                                CornerRadius="3" Padding="2">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CtxMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                CornerRadius="2">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A55"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A55"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333350"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8E8F0"/>
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="BorderBrush" Value="#808098"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════ MENU BAR ══════════════════════════════════════════ -->
        <Menu Grid.Row="0" Background="#252538" Foreground="#E0E0E0" FontSize="12" Padding="4,2">
            <MenuItem Header="Settings">
                <MenuItem Header="Measurement Setup" Click="OnMeasurementSetupClick"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <StackPanel>
                        <TextBlock Text="SURFACE TENSION" FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="Designed and Developed by Soranan Suebsilpasakul" FontSize="9" 
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>

                        <TextBlock Text="CONNECTION" FontSize="10" FontWeight="Bold" 
                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6"/>
                        <Border Background="{StaticResource BgBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding AvailablePorts}" 
                                          SelectedItem="{Binding SelectedPort}" Margin="0,0,6,0"/>
                                    <Button Grid.Column="1" Content="⟳" 
                                        Style="{StaticResource DarkButton}"
                                        Command="{Binding RefreshPortsCommand}" ToolTip="Refresh ports"/>
                                </Grid>
                                <Button Command="{Binding ToggleConnectCommand}" Margin="0,0,0,4"
                                    Style="{StaticResource DarkButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                                             Fill="{Binding IsConnected, Converter={StaticResource ConnBrush}}"/>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Connect"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                            <Setter Property="Text" Value="Disconnect"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding ConnectionStatus}" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="MANUAL CONTROL" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,6"/>
                        <Border Background="{StaticResource BgBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <Button Content="Enter Manual Control Mode" Command="{Binding EnterEncoderModeCommand}"
                                    Style="{StaticResource DarkButton}" Margin="0,0,0,6"
                                    Visibility="{Binding IsEncoderMode, Converter={StaticResource InvBoolVis}}"/>
                                <StackPanel Visibility="{Binding IsEncoderMode, Converter={StaticResource BoolVis}}">
                                    <UniformGrid Columns="2" Margin="0,0,0,6">
                                        <Button Content="Set Home" Command="{Binding EncoderSetHomeCommand}"
                                            Style="{StaticResource DarkButton}" Margin="0,0,3,3"/>
                                        <Button Content="Set Target" Command="{Binding EncoderSetTargetCommand}"
                                            Style="{StaticResource DarkButton}" Margin="3,0,0,3"/>
                                        <Button Content="Go Home" Command="{Binding EncoderGoHomeCommand}"
                                            Style="{StaticResource DarkButton}" Margin="0,0,3,3"/>
                                        <Button Content="Go Target" Command="{Binding EncoderGoTargetCommand}"
                                            Style="{StaticResource DarkButton}" Margin="3,0,0,3"/>
                                    </UniformGrid>
                                    <Button Content="Tare" Command="{Binding EncoderTareCommand}"
                                        Style="{StaticResource DarkButton}" Margin="0,0,0,6"/>
                                    <Button Content="Exit Manual Control" Command="{Binding ExitEncoderModeCommand}"
                                        Style="{StaticResource RedButton}" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Home: " Foreground="{StaticResource TextDimBrush}"/>
                                        <TextBlock Text="{Binding EncoderHome}" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target: " Foreground="{StaticResource TextDimBrush}"/>
                                        <TextBlock Text="{Binding EncoderTarget}" Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="SPEED TESTS" FontSize="10" FontWeight="Bold" 
                               Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,6"/>
                        <Border Background="{StaticResource BgBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <Button Content="1: Ultra Fast (600 µm/s)" Style="{StaticResource DarkButton}" 
                                    Command="{Binding RunSpeedCommand}" CommandParameter="1" Margin="0,0,0,3"/>
                                <Button Content="2: Fast Up (400 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="2" Margin="0,0,0,3"/>
                                <Button Content="3: V8 (133.5 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="3" Margin="0,0,0,3"/>
                                <Button Content="4: V6 (100.125 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="4" Margin="0,0,0,3"/>
                                <Button Content="5: V4 (66.75 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="5" Margin="0,0,0,3"/>
                                <Button Content="6: V2 (33.3375 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="6" Margin="0,0,0,3"/>
                                <Button Content="7: Measure F (18.75 µm/s)" Style="{StaticResource DarkButton}"
                                    Command="{Binding RunSpeedCommand}" CommandParameter="7" Margin="0,0,0,3"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="CUSTOM AUTO" FontSize="10" FontWeight="Bold" 
                               Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,6"/>
                        <Border Background="{StaticResource BgBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Repeats:" Foreground="{StaticResource TextDimBrush}" 
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Text="{Binding CustomRepeatCount, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="50" FontSize="13" Padding="4,2"
                                         Background="#2A2A3E" Foreground="White"
                                         BorderBrush="{StaticResource BorderBrush}" CaretBrush="White"/>
                                    <TextBlock Text=" x speed" Foreground="{StaticResource TextDimBrush}" 
                                           VerticalAlignment="Center"/>
                                </StackPanel>
                                <ComboBox ItemsSource="{Binding SpeedOptions}" 
                                      SelectedItem="{Binding SelectedSpeedOption}"
                                      Margin="0,0,0,6"/>
                                <Button Content="▶ Run Custom Auto" Command="{Binding RunCustomAutoCommand}"
                                    Style="{StaticResource GreenButton}" FontWeight="Bold" 
                                    FontSize="12" Padding="10,8"/>
                            </StackPanel>
                        </Border>

                        <Button Content="▶ Full Auto (140 runs)" Command="{Binding RunAutoSequenceCommand}"
                            Style="{StaticResource GreenButton}" FontWeight="Bold" 
                            FontSize="13" Padding="12,10" Margin="0,0,0,10"/>

                        <TextBlock Text="UTILITIES" FontSize="10" FontWeight="Bold" 
                               Foreground="{StaticResource TextDimBrush}" Margin="0,6,0,6"/>
                        <UniformGrid Columns="2" Margin="0,0,0,6">
                            <Button Content="Calibrate" Command="{Binding CalibrateCommand}"
                                Style="{StaticResource DarkButton}" Margin="0,0,3,3"/>
                            <Button Content="Tare" Command="{Binding TareCommand}"
                                Style="{StaticResource DarkButton}" Margin="3,0,0,3"/>
                            <Button Content="Go Target" Command="{Binding GoTargetCommand}"
                                Style="{StaticResource DarkButton}" Margin="0,0,3,3"/>
                            <Button Content="Go Home" Command="{Binding GoHomeCommand}"
                                Style="{StaticResource DarkButton}" Margin="3,0,0,3"/>
                        </UniformGrid>
                        <Button Content="Monitor" Command="{Binding MonitorCommand}"
                            Style="{StaticResource DarkButton}" Margin="0,0,0,10"/>

                        <Button Command="{Binding EmergencyStopCommand}"
                            Style="{StaticResource RedButton}" FontSize="14" Padding="12,12" Margin="0,0,0,4">
                            <Button.Content>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="⚠ EMERGENCY STOP"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmergencyLocked}" Value="True">
                                                    <Setter Property="Text" Value="🔒 LOCKED — Click to Unlock"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BgBrush}" 
                    CornerRadius="6" Padding="4" Margin="0,0,0,4">
                    <Grid>
                        <scott:WpfPlot x:Name="PlotControl"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,8,8,0">
                            <Button Content="◀" ToolTip="Undo zoom/pan" x:Name="BtnUndo"
                                Style="{StaticResource DarkButton}" Width="39" Margin="0,0,3,0" 
                                Opacity="0.8" Click="OnGraphUndo" FontSize="12"/>
                            <Button Content="▶" ToolTip="Redo zoom/pan" x:Name="BtnRedo"
                                Style="{StaticResource DarkButton}" Width="39" Margin="0,0,3,0"
                                Opacity="0.8" Click="OnGraphRedo" FontSize="12"/>
                            <Button Content="Home" ToolTip="Reset zoom" x:Name="BtnHome"
                                Style="{StaticResource DarkButton}" Width="59" Margin="0,0,3,0"
                                Opacity="0.8" FontSize="11" Click="OnGraphHome"/>
                            <ToggleButton Content="Filter Spikes"
                                      IsChecked="{Binding IsSpikeFilterEnabled}"
                                      Style="{StaticResource SpikeFilterToggle}"
                                      Opacity="0.8" Margin="0,0,3,0"
                                      ToolTip="Toggle spike noise filter on/off" Width="103"/>
                            <TextBlock Text="Max:" Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center" FontSize="10" Margin="4,0,2,0" Width="26"/>
                            <TextBox Text="{Binding SpikeThresholdText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="70" FontSize="10" Padding="3,2"
                                 Background="#2A2A3E" Foreground="White" CaretBrush="White"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 VerticalAlignment="Center"
                                 ToolTip="Max force threshold (N). Leave empty for auto-detect."/>
                            <TextBlock Text="N" Foreground="{StaticResource TextDimBrush}"
                                   VerticalAlignment="Center" FontSize="10" Margin="2,0,3,0"/>
                            <Button Content="Clear Graph" Command="{Binding ClearGraphCommand}"
                                Style="{StaticResource DarkButton}" Opacity="0.8" Width="113"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" 
                    CornerRadius="6" Padding="10" Margin="0,0,0,8"
                    Visibility="{Binding IsAutoRunning, Converter={StaticResource BoolVis}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AutoStatusText}" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource AccentBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentBatchText}" Margin="0,0,12,0"
                                       Foreground="{StaticResource TextDimBrush}"/>
                                <TextBlock Text="{Binding CurrentSpeedText}" Margin="0,0,12,0"
                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CurrentRunText}" 
                                       Foreground="{StaticResource TextDimBrush}"/>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Value="{Binding AutoProgress}" Maximum="{Binding AutoTotal}" Height="22"/>
                        <TextBlock Text="{Binding LastPeakText}" Margin="0,4,0,0" FontSize="13"
                               Foreground="{StaticResource GreenBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="{StaticResource BgBrush}" 
                    CornerRadius="6" Padding="6" MaxHeight="180">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="SERIAL LOG" FontSize="10" FontWeight="Bold" 
                                   Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                            <CheckBox Content="Show" IsChecked="{Binding ShowSerialLog}" Margin="12,0"
                                  Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBox Grid.Row="1" x:Name="LogTextBox"
                             Text="{Binding SerialLog, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Background="Black" Foreground="#88FF88" 
                             FontFamily="Consolas" FontSize="10" BorderThickness="0"
                             Visibility="{Binding ShowSerialLog, Converter={StaticResource BoolVis}}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" 
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="STATISTICS" FontSize="10" FontWeight="Bold" 
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding StatsRows}" 
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
                          RowBackground="{StaticResource BgBrush}" 
                          AlternatingRowBackground="{StaticResource BgLightBrush}"
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          HeadersVisibility="Column" FontSize="11"
                          CanUserResizeColumns="True" CanUserSortColumns="True"
                          Margin="0,0,0,10">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Speed" Binding="{Binding SpeedName}" Width="70"/>
                            <DataGridTextColumn Header="B" Binding="{Binding Batch}" Width="26"/>
                            <DataGridTextColumn Header="Runs" Binding="{Binding ValidRuns}" Width="36"/>
                            <DataGridTextColumn Header="Avg (N)" Binding="{Binding Average, StringFormat=F6}" Width="72"/>
                            <DataGridTextColumn Header="SD (N)" Binding="{Binding StdDev, StringFormat=F6}" Width="72"/>
                            <DataGridTextColumn Header="RSD%" Binding="{Binding RsdPercent, StringFormat=F2}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="RUN RESULTS" FontSize="10" FontWeight="Bold" 
                           Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6"/>

                    <DataGrid Grid.Row="3" ItemsSource="{Binding RunResults}" 
                          SelectedItem="{Binding SelectedRunResult}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
                          RowBackground="{StaticResource BgBrush}" 
                          AlternatingRowBackground="{StaticResource BgLightBrush}"
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderBrush="{StaticResource BorderBrush}"
                          HeadersVisibility="Column" FontSize="11"
                          Margin="0,0,0,10">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="✓ Toggle Outlier (Mark/Unmark)"
                                      Command="{Binding ToggleOutlierCommand}"
                                      Style="{StaticResource CtxMenuItem}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource BgLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="6,4"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <!-- Visibility checkbox -->
                            <DataGridTemplateColumn Header="👁" Width="28">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsVisible, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Tag="{Binding}" HorizontalAlignment="Center"
                                              Checked="OnVisibilityToggle" Unchecked="OnVisibilityToggle"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Color swatch -->
                            <DataGridTemplateColumn Header="🎨" Width="28">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Width="16" Height="16" Tag="{Binding}"
                                            Click="OnColorSwatchClick" Cursor="Hand"
                                            ToolTip="Click to change color"
                                            BorderThickness="1" BorderBrush="#555577">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bd" Width="16" Height="16" CornerRadius="2"
                                                                    BorderThickness="1" BorderBrush="#555577"
                                                                    Background="{Binding ColorHex, Converter={StaticResource HexBrush}}"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Speed" Binding="{Binding SpeedName}" Width="60"/>
                            <DataGridTextColumn Header="B" Binding="{Binding Batch}" Width="22"/>
                            <DataGridTextColumn Header="#" Binding="{Binding RunNumber}" Width="22"/>
                            <DataGridTextColumn Header="Peak (N)" Binding="{Binding PeakForce, StringFormat=F5}" Width="72"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="52"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOutlier}" Value="True">
                                        <Setter Property="Background" Value="#441111"/>
                                        <Setter Property="Foreground" Value="#FF6666"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                    <StackPanel Grid.Row="4">
                        <Button Content="📊 Export Excel (.xlsx)" Command="{Binding ExportExcelCommand}"
                            Style="{StaticResource DarkButton}" Margin="0,0,0,6" FontSize="13" Padding="12,10"/>
                        <Button Content="📄 Export PDF Report" Command="{Binding ExportPdfCommand}"
                            Style="{StaticResource DarkButton}" Margin="0,0,0,6" FontSize="13" Padding="12,10"/>
                        <Button Content="🗑 Clear All Data" Command="{Binding ClearAllCommand}"
                            Style="{StaticResource RedButton}" Margin="0,0,0,4"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Text="SESSION HISTORY" FontSize="10" FontWeight="Bold" 
                           Foreground="{StaticResource AccentBrush}" Margin="0,12,0,4"/>
                    <ListBox Grid.Row="6" ItemsSource="{Binding Sessions}" 
                         SelectedItem="{Binding SelectedSession}"
                         Background="{StaticResource BgBrush}" 
                         Foreground="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         FontSize="10" MaxHeight="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="📂 Load" Command="{Binding LoadSessionCommand}"
                            Style="{StaticResource DarkButton}" Width="70" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🆕 New" Command="{Binding NewSessionCommand}"
                            Style="{StaticResource DarkButton}" Width="70" Margin="0,0,4,0" FontSize="11"/>
                        <Button Content="🗑 Delete" Command="{Binding DeleteSessionCommand}"
                            Style="{StaticResource DarkButton}" Width="83" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>