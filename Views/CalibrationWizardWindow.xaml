<Window x:Class="SurfaceTensionApp.Views.CalibrationWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibration Wizard"
        Width="520" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E2E"
        FontFamily="Inter">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StepTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4A9EFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="StepDesc" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0C8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#4A9EFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="16,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A7EDC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3A3A52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="12,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A55"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Step indicator bar -->
        <Border Grid.Row="0" Background="#252538" Padding="16,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="Step1Dot" Text="1" FontSize="13" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Width="28" TextAlignment="Center"
                               Padding="0,3" Background="#4A9EFF" Margin="0,0,4,0"/>
                    <TextBlock Text="—" Foreground="#3A3A52" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step2Dot" Text="2" FontSize="13" FontWeight="Bold"
                               Foreground="#808098" HorizontalAlignment="Center" Width="28" TextAlignment="Center"
                               Padding="0,3" Background="#2A2A3E" Margin="0,0,4,0"/>
                    <TextBlock Text="—" Foreground="#3A3A52" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step3Dot" Text="3" FontSize="13" FontWeight="Bold"
                               Foreground="#808098" HorizontalAlignment="Center" Width="28" TextAlignment="Center"
                               Padding="0,3" Background="#2A2A3E" Margin="0,0,4,0"/>
                    <TextBlock Text="—" Foreground="#3A3A52" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step4Dot" Text="4" FontSize="13" FontWeight="Bold"
                               Foreground="#808098" HorizontalAlignment="Center" Width="28" TextAlignment="Center"
                               Padding="0,3" Background="#2A2A3E" Margin="0,0,4,0"/>
                    <TextBlock Text="—" Foreground="#3A3A52" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock x:Name="Step5Dot" Text="5" FontSize="13" FontWeight="Bold"
                               Foreground="#808098" HorizontalAlignment="Center" Width="28" TextAlignment="Center"
                               Padding="0,3" Background="#2A2A3E"/>
                </StackPanel>
                <TextBlock x:Name="StepLabel" Text="Preparation" HorizontalAlignment="Center"
                           Foreground="#808098" FontSize="10" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Step content area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <Grid>
                <!-- ═══ Step 1: Preparation ═══ -->
                <StackPanel x:Name="PanelStep1">
                    <TextBlock Text="Step 1: Preparation" Style="{StaticResource StepTitle}"/>
                    <TextBlock Style="{StaticResource StepDesc}">
                        Before calibrating, make sure the system is ready.
                    </TextBlock>

                    <Border Background="#252538" CornerRadius="6" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Checklist:" FontWeight="Bold" Foreground="#4A9EFF" Margin="0,0,0,8"/>
                            <TextBlock Text="1. Arduino is connected and powered on" Margin="0,0,0,4"/>
                            <TextBlock Text="2. Load cell is firmly mounted and stable" Margin="0,0,0,4"/>
                            <TextBlock Text="3. Remove ALL weight from the load cell" Margin="0,0,0,4"/>
                            <TextBlock Text="4. Prepare a known calibration weight (e.g. 20g)" Margin="0,0,0,4"/>
                            <TextBlock Text="5. Ensure no vibration or air currents" Margin="0,0,0,4"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Load Cell Type" Foreground="#808098" FontSize="11" Margin="0,0,0,4"/>
                    <Border Background="#252538" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                        <StackPanel>
                            <RadioButton x:Name="Radio100g" Content="100g Load Cell (current)" Foreground="#E0E0E0"
                                         IsChecked="True" Margin="0,0,0,6" GroupName="LoadCell"/>
                            <RadioButton x:Name="Radio30g" Content="30g Load Cell (high precision)" Foreground="#E0E0E0"
                                         GroupName="LoadCell"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="ConnectionWarning" Text="⚠ Arduino is not connected!"
                               Foreground="#FF6666" FontWeight="Bold" Visibility="Collapsed" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- ═══ Step 2: Tare (Zero) ═══ -->
                <StackPanel x:Name="PanelStep2" Visibility="Collapsed">
                    <TextBlock Text="Step 2: Tare (Zero Point)" Style="{StaticResource StepTitle}"/>
                    <TextBlock Style="{StaticResource StepDesc}">
                        With NO weight on the load cell, press Tare to set the zero reference point.
                        Make sure the platform is completely empty and stable.
                    </TextBlock>

                    <Border Background="#252538" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Live Force Reading:" Foreground="#808098" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="LiveForceStep2" Text="— N" FontSize="24" FontWeight="Bold"
                                       Foreground="#44FF88" HorizontalAlignment="Center" Margin="0,4,0,8"/>
                            <TextBlock Text="(should be near 0.00000 N after tare)"
                                       Foreground="#666680" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Tare Now" Click="OnTareClick" Style="{StaticResource ActionBtn}"
                            HorizontalAlignment="Center" Width="160"/>

                    <TextBlock x:Name="TareStatus" Text="" Foreground="#44FF88" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- ═══ Step 3: Place Known Weight ═══ -->
                <StackPanel x:Name="PanelStep3" Visibility="Collapsed">
                    <TextBlock Text="Step 3: Place Known Weight" Style="{StaticResource StepTitle}"/>
                    <TextBlock Style="{StaticResource StepDesc}">
                        Gently place your calibration weight on the load cell center.
                        Wait for the reading to stabilize before proceeding.
                    </TextBlock>

                    <Border Background="#252538" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Enter the known weight:" Foreground="#808098" FontSize="11" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBox x:Name="KnownWeightBox" Width="120" FontSize="16" Padding="8,4"
                                         Background="#2A2A3E" Foreground="White" CaretBrush="White"
                                         BorderBrush="#3A3A52" TextAlignment="Center" Text="20.00"/>
                                <TextBlock Text=" grams" VerticalAlignment="Center" FontSize="14" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Text="Live Force Reading:" Foreground="#808098" FontSize="11" Margin="0,6,0,6"/>
                            <TextBlock x:Name="LiveForceStep3" Text="— N" FontSize="24" FontWeight="Bold"
                                       Foreground="#FFD93D" HorizontalAlignment="Center"/>
                            <TextBlock Text="(wait until reading is stable)"
                                       Foreground="#666680" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══ Step 4: Calibrate ═══ -->
                <StackPanel x:Name="PanelStep4" Visibility="Collapsed">
                    <TextBlock Text="Step 4: Calibrate" Style="{StaticResource StepTitle}"/>
                    <TextBlock Style="{StaticResource StepDesc}">
                        The known weight should still be on the load cell.
                        Press Calibrate to send the calibration command to the Arduino.
                        The Arduino will calculate and store the new calibration factor.
                    </TextBlock>

                    <Border Background="#252538" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock x:Name="CalWeightSummary" Text="Known weight: 20.00 g"
                                       FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock x:Name="CalLoadCell" Text="Load cell: 100g"
                                       FontSize="13" HorizontalAlignment="Center" Foreground="#808098" Margin="0,0,0,8"/>
                            <TextBlock x:Name="LiveForceStep4" Text="— N" FontSize="24" FontWeight="Bold"
                                       Foreground="#FFD93D" HorizontalAlignment="Center" Margin="0,4,0,8"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Calibrate Now" Click="OnCalibrateClick" Style="{StaticResource ActionBtn}"
                            HorizontalAlignment="Center" Width="180"/>

                    <TextBlock x:Name="CalStatus" Text="" Foreground="#44FF88" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>

                <!-- ═══ Step 5: Verify ═══ -->
                <StackPanel x:Name="PanelStep5" Visibility="Collapsed">
                    <TextBlock Text="Step 5: Verify" Style="{StaticResource StepTitle}"/>
                    <TextBlock Style="{StaticResource StepDesc}">
                        Calibration command sent! Now verify the results:
                        1. Remove the weight — reading should return to ~0 N
                        2. Place the weight again — check the force reading
                    </TextBlock>

                    <Border Background="#252538" CornerRadius="6" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Live Force Reading:" Foreground="#808098" FontSize="11" Margin="0,0,0,6"/>
                            <TextBlock x:Name="LiveForceStep5" Text="— N" FontSize="28" FontWeight="Bold"
                                       Foreground="#44FF88" HorizontalAlignment="Center" Margin="0,4,0,8"/>
                            <TextBlock x:Name="ExpectedForce" Text="Expected: ~0.19620 N for 20.00 g"
                                       Foreground="#808098" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#114422" CornerRadius="6" Padding="14" BorderBrush="#44FF88" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Calibration Complete" FontWeight="Bold" FontSize="14"
                                       Foreground="#44FF88" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" Foreground="#B0B0C8" FontSize="11" TextAlignment="Center">
                                The calibration factor is stored in the Arduino's EEPROM
                                and will persist across power cycles.
                                You can close this wizard and begin measuring.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Bottom navigation bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#3A3A52"
                Background="#252538" Padding="20,10">
            <Grid>
                <Button x:Name="BtnBack" Content="Back" Click="OnBackClick"
                        Style="{StaticResource NavBtn}" HorizontalAlignment="Left"
                        IsEnabled="False"/>
                <Button x:Name="BtnNext" Content="Next" Click="OnNextClick"
                        Style="{StaticResource ActionBtn}" HorizontalAlignment="Right"
                        Width="100"/>
            </Grid>
        </Border>
    </Grid>
</Window>
